global:
  scrape_interval: 15s

scrape_configs:
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:9090"]

  - job_name: "node_exporter"
    static_configs:
      - targets:
{% for t in web_targets %}
        - "{{ t.host }}:{{ node_exporter_port }}"
{% endfor %}

  - job_name: "nginxlog_exporter"
    metrics_path: /metrics
    static_configs:
      - targets:
{% for t in web_targets %}
        - "{{ t.host }}:{{ nginxlog_exporter_port }}"
{% endfor %}
