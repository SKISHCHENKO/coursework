filebeat.inputs:
  - type: filestream
    id: nginx-access
    enabled: true
    paths:
      - /var/log/nginx/access.log
  - type: filestream
    id: nginx-error
    enabled: true
    paths:
      - /var/log/nginx/error.log

output.elasticsearch:
  hosts: ["http://{{ elasticsearch_host }}:{{ elasticsearch_port }}"]

setup.ilm.enabled: false
setup.template.enabled: true
